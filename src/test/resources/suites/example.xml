<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Example API">
    <test name="Example Positive Test" preserve-order="true">
        <groups>
            <run>
                <include name="positive"/>
            </run>
        </groups>
        <packages>
            <package name="com.example.domain.example.*"/>
        </packages>
    </test> <!-- Test -->
    <test name="Example Negative Test" preserve-order="true">
        <groups>
            <run>
                <include name="negative"/>
            </run>
        </groups>
        <packages>
            <package name="com.example.domain.example.*"/>
        </packages>
    </test> <!-- Test -->
</suite> <!-- Suite -->